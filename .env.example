PORT=8080
NODE_ENV=development
MONGODB_URL=mongodb://localhost:27017/digital-tests

# JWT secrets — generate 32+ random bytes per key (e.g. `openssl rand -hex 32`).
# Each key signs a different token type per API_CONTRACT.md §3.1.
# Real values MUST live in .env.local (gitignored). The values below are
# placeholders that the boot-time check in src/config/index.ts will reject —
# any string containing `please-replace-with` refuses to start the server.
JWT_USER_ACCESS_KEY=dev-access-key-please-replace-with-32+-random-chars
JWT_USER_ACTIVATION_KEY=dev-activation-key-please-replace-with-32+-random-chars
JWT_RESET_PASSWORD_KEY=dev-reset-key-please-replace-with-32+-random-chars
JWT_QUIZ_SECRET_KEY=dev-quiz-secret-please-replace-with-32+-random-chars

# Frontend the API redirects/links back to (activation links, reset links, etc.).
FRONTEND_URL=http://localhost:5173

# Comma-separated list of origins permitted by Express CORS. Server refuses to boot if empty.
ALLOWED_ORIGINS=http://localhost:5173

# Outgoing email "From" header.
MAIL_FROM=noreply@digital-tests.local

# Mailtrap SMTP credentials. Leave both blank in dev to disable email — the server
# logs a warning and no-ops instead of failing requests. Required in staging/prod.
# These are SECRETS — put real values in .env.local (gitignored), not here.
MAILTRAP_USER=
MAILTRAP_PASS=

BCRYPT_COST=12
