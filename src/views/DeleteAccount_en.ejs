<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="color-scheme" content="light only" />
    <meta name="supported-color-schemes" content="light only" />
    <title>Your Digital Tests account has been deleted</title>
    <!--[if mso]>
    <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
    <![endif]-->
    <style>
      body { margin: 0; padding: 0; }
      table { border-collapse: collapse; }
      a { color: #5048E5; }
    </style>
  </head>
  <body style="margin:0; padding:0; background-color:#FBFAF7; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; color:#1C1A19;">
    <div style="display:none; max-height:0; overflow:hidden; mso-hide:all; font-size:1px; line-height:1px; color:#FBFAF7;">Your Digital Tests account has been permanently deleted.</div>

    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#FBFAF7;">
      <tr>
        <td align="center" style="padding: 40px 16px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px; width:100%;">

            <tr>
              <td align="center" style="padding-bottom:24px;">
                <span style="font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:20px; font-weight:700; color:#5048E5; letter-spacing:-0.01em;">Digital Tests</span>
              </td>
            </tr>

            <tr>
              <td style="background-color:#FFFFFF; border:1px solid #DBD8D5; border-radius:8px; padding:40px 32px;">
                <h1 style="margin:0 0 16px 0; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:22px; font-weight:700; color:#1C1A19; line-height:1.3;">
                  Goodbye, <%= name %>
                </h1>
                <p style="margin:0 0 16px 0; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:15px; line-height:1.6; color:#1C1A19;">
                  Your Digital Tests account has been permanently deleted. Your tests, scores, and personal data have all been removed from our systems.
                </p>
                <p style="margin:0 0 16px 0; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:15px; line-height:1.6; color:#1C1A19;">
                  We're sorry to see you go. If you ever change your mind, you're always welcome back.
                </p>
                <p style="margin:24px 0 0 0; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:13px; line-height:1.6; color:#726B66;">
                  Thank you for being part of Digital Tests.
                </p>
              </td>
            </tr>

            <tr>
              <td align="center" style="padding-top:24px; font-family:'Helvetica Neue',Helvetica,Arial,sans-serif; font-size:12px; color:#726B66; line-height:1.6;">
                &copy; Digital Tests
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
